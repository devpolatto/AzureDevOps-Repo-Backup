# ──────────────────────────────────────────────
# Configuração do Backup Azure DevOps
# ──────────────────────────────────────────────
# Copie este arquivo para .env e preencha com seus valores

# Personal Access Token do Azure DevOps
# Gere em: https://dev.azure.com/<organization>/_usersSettings/tokens
# Escopos necessários: Code (Read)
AZURE_PAT=your_personal_access_token_here

# Nome da organização no Azure DevOps (padrão: MyOrganization)
ORGANIZATION=MyOrganization

# Caminho local onde salvar os backups (padrão: ./Backup-AzureDevOps/MyOrganization)
BACKUP_PATH=./Backup-AzureDevOps/MyOrganization

# Versão da API do Azure DevOps (padrão: 7.1)
# API_VERSION=
